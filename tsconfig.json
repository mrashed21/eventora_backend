{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2023",
    "rootDir": "./src",
    "outDir": "./dist",

    // "baseUrl": ".",
    // "paths": {
    //   "@/*": ["src/*"],
    //   "@generated/*": ["prisma/generated/*"]
    // },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
