<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Your Email</title>
  </head>

  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #f1f5f9;
      font-family: Arial, Helvetica, sans-serif;
    "
  >
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      style="background-color: #f1f5f9; padding: 40px 16px"
    >
      <tr>
        <td align="center">
          <!-- Outer Container -->
          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            style="max-width: 520px"
          >
            <!-- Brand / Top -->
            <tr>
              <td align="center" style="padding-bottom: 20px">
                <div
                  style="
                    display: inline-block;
                    background: #10b981;
                    color: #ffffff;
                    font-size: 22px;
                    font-weight: bold;
                    width: 56px;
                    height: 56px;
                    line-height: 56px;
                    text-align: center;
                    border-radius: 16px;
                  "
                >
                  🔐
                </div>
              </td>
            </tr>

            <!-- Main Card -->
            <tr>
              <td
                style="
                  background: #ffffff;
                  border-radius: 20px;
                  padding: 40px 32px;
                  box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
                "
              >
                <!-- Header -->
                <table width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td align="center" style="padding-bottom: 10px">
                      <h1
                        style="
                          margin: 0;
                          font-size: 28px;
                          line-height: 1.3;
                          color: #0f172a;
                          font-weight: 700;
                        "
                      >
                        Verify Your Email
                      </h1>
                    </td>
                  </tr>

                  <tr>
                    <td
                      align="center"
                      style="
                        color: #64748b;
                        font-size: 15px;
                        line-height: 1.7;
                        padding-bottom: 28px;
                      "
                    >
                      Use the one-time verification code below to complete your
                      sign in or email verification process.
                    </td>
                  </tr>

                  <!-- Greeting -->
                  <tr>
                    <td
                      style="
                        color: #0f172a;
                        font-size: 16px;
                        line-height: 1.7;
                        padding-bottom: 14px;
                      "
                    >
                      Hello
                      <strong style="text-transform: capitalize"
                        ><%= name %></strong
                      >,
                    </td>
                  </tr>

                  <!-- Main Message -->
                  <tr>
                    <td
                      style="
                        color: #475569;
                        font-size: 15px;
                        line-height: 1.8;
                        padding-bottom: 26px;
                      "
                    >
                      We received a request to verify your email address. Enter
                      the following OTP code in the app or website to continue.
                    </td>
                  </tr>

                  <!-- OTP Label -->
                  <tr>
                    <td
                      align="center"
                      style="
                        color: #64748b;
                        font-size: 13px;
                        font-weight: bold;
                        letter-spacing: 1px;
                        text-transform: uppercase;
                        padding-bottom: 12px;
                      "
                    >
                      Your Verification Code
                    </td>
                  </tr>

                  <!-- OTP Box -->
                  <tr>
                    <td align="center" style="padding-bottom: 24px">
                      <div
                        style="
                          display: inline-block;
                          background: linear-gradient(135deg, #ecfdf5, #d1fae5);
                          border: 1px solid #a7f3d0;
                          border-radius: 16px;
                          padding: 18px 28px;
                          min-width: 220px;
                          text-align: center;
                        "
                      >
                        <span
                          style="
                            font-size: 34px;
                            line-height: 1;
                            font-weight: 800;
                            letter-spacing: 10px;
                            color: #065f46;
                            display: inline-block;
                          "
                        >
                          <%= otp %>
                        </span>
                      </div>
                    </td>
                  </tr>

                  <!-- Expiry -->
                  <tr>
                    <td
                      align="center"
                      style="
                        font-size: 14px;
                        color: #475569;
                        line-height: 1.7;
                        padding-bottom: 24px;
                      "
                    >
                      This code will expire in
                      <strong style="color: #0f172a">60 minutes</strong>.
                    </td>
                  </tr>

                  <!-- Security Note -->
                  <tr>
                    <td style="padding-bottom: 24px">
                      <table
                        width="100%"
                        cellpadding="0"
                        cellspacing="0"
                        style="
                          background: #fff7ed;
                          border: 1px solid #fed7aa;
                          border-radius: 14px;
                        "
                      >
                        <tr>
                          <td
                            style="
                              padding: 16px 18px;
                              color: #9a3412;
                              font-size: 14px;
                              line-height: 1.7;
                            "
                          >
                            <strong>Security Tip:</strong> Never share this code
                            with anyone. Our team will never ask for your OTP by
                            email, phone, or message.
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>

                  <!-- Secondary Note -->
                  <tr>
                    <td
                      style="
                        color: #64748b;
                        font-size: 14px;
                        line-height: 1.8;
                        padding-bottom: 28px;
                      "
                    >
                      If you did not request this verification, you can safely
                      ignore this email. No further action is needed.
                    </td>
                  </tr>

                  <!-- Divider -->
                  <tr>
                    <td
                      style="
                        border-top: 1px solid #e2e8f0;
                        padding-top: 20px;
                        color: #94a3b8;
                        font-size: 12px;
                        line-height: 1.8;
                        text-align: center;
                      "
                    >
                      This is an automated security email. Please do not reply
                      to this message.
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                align="center"
                style="
                  padding-top: 20px;
                  color: #94a3b8;
                  font-size: 12px;
                  line-height: 1.8;
                "
              >
                © <%= new Date().getFullYear() %> Your Company. All rights
                reserved.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
