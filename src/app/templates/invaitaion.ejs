<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>You're Invited</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #f4f6f8;
      font-family: Arial, sans-serif;
    "
  >
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      style="padding: 30px 12px"
    >
      <tr>
        <td align="center">
          <table
            width="520"
            cellpadding="0"
            cellspacing="0"
            style="
              background: #ffffff;
              border-radius: 16px;
              overflow: hidden;
              box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            "
          >
            <!-- HEADER -->
            <tr>
              <td
                align="center"
                style="
                  background: linear-gradient(135deg, #10b981, #059669);
                  padding: 40px 30px;
                  color: #ffffff;
                "
              >
                <div style="font-size: 42px">🎉</div>
                <h1 style="margin: 10px 0 0; font-size: 26px">
                  You're Invited!
                </h1>
                <p style="margin: 10px 0 0; font-size: 14px; color: #d1fae5">
                  Join an exciting event and be part of something amazing.
                </p>
              </td>
            </tr>

            <!-- BODY -->
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
