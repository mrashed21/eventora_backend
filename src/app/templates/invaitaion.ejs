<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>You're Invited</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #f4f6f8;
      font-family: Arial, sans-serif;
    "
  >
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      style="padding: 40px 15px"
    >
      <tr>
        <td align="center">
          <!-- Main Card -->
          <table
            width="520"
            cellpadding="0"
            cellspacing="0"
            style="
              background: #ffffff;
              border-radius: 16px;
              overflow: hidden;
              box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
            "
          >
            <!-- Header -->
            <tr>
              <td
                align="center"
                style="
                  background: linear-gradient(135deg, #10b981, #059669);
                  padding: 40px 30px;
                  color: #ffffff;
                "
              >
                <div style="font-size: 42px; margin-bottom: 12px">🎉</div>
                <h1
                  style="
                    margin: 0;
                    font-size: 28px;
                    font-weight: bold;
                    color: #ffffff;
                  "
                >
                  You're Invited!
                </h1>
                <p
                  style="
                    margin: 12px 0 0;
                    font-size: 15px;
                    color: #d1fae5;
                    line-height: 1.6;
                  "
                >
                  You’ve received an invitation to join an exciting event.
                </p>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding: 35px 30px 10px">
                <p
                  style="
                    margin: 0 0 16px;
                    color: #1f2937;
                    font-size: 16px;
                    line-height: 1.7;
                  "
                >
                  Hello,
                </p>

                <p
                  style="
                    margin: 0 0 22px;
                    color: #4b5563;
                    font-size: 15px;
                    line-height: 1.8;
                  "
                >
                  You have been invited to attend the following event:
                </p>

                <!-- Event Info Card -->
                <table
                  width="100%"
                  cellpadding="0"
                  cellspacing="0"
                  style="
                    background: #f9fafb;
                    border: 1px solid #e5e7eb;
                    border-radius: 12px;
                    padding: 20px;
                    margin-bottom: 28px;
                  "
                >
                  <tr>
                    <td style="padding-bottom: 10px">
                      <p
                        style="
                          margin: 0;
                          font-size: 13px;
                          color: #6b7280;
                          text-transform: uppercase;
                          letter-spacing: 0.5px;
                        "
                      >
                        Event Name
                      </p>
                      <p
                        style="
                          margin: 6px 0 0;
                          font-size: 22px;
                          font-weight: bold;
                          color: #111827;
                          line-height: 1.5;
                        "
                      >
                        <%= eventName %>
                      </p>
                    </td>
                  </tr>

                  <% if (eventDate) { %>
                  <tr>
                    <td style="padding-top: 10px">
                      <p
                        style="
                          margin: 0;
                          font-size: 13px;
                          color: #6b7280;
                          text-transform: uppercase;
                          letter-spacing: 0.5px;
                        "
                      >
                        Date
                      </p>
                      <p
                        style="
                          margin: 6px 0 0;
                          font-size: 15px;
                          color: #1f2937;
                        "
                      >
                        <%= eventDate %>
                      </p>
                    </td>
                  </tr>
                  <% } %> <% if (eventLocation) { %>
                  <tr>
                    <td style="padding-top: 16px">
                      <p
                        style="
                          margin: 0;
                          font-size: 13px;
                          color: #6b7280;
                          text-transform: uppercase;
                          letter-spacing: 0.5px;
                        "
                      >
                        Location
                      </p>
                      <p
                        style="
                          margin: 6px 0 0;
                          font-size: 15px;
                          color: #1f2937;
                          line-height: 1.6;
                        "
                      >
                        <%= eventLocation %>
                      </p>
                    </td>
                  </tr>
                  <% } %>
                </table>

                <p
                  style="
                    margin: 0 0 26px;
                    color: #4b5563;
                    font-size: 15px;
                    line-height: 1.8;
                  "
                >
                  We’d love to have you join us. Click the button below to view
                  the event details and respond to the invitation.
                </p>

                <!-- CTA Button -->
                <% if (inviteLink) { %>
                <table width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td align="center" style="padding-bottom: 30px">
                      <a
                        href="<%= inviteLink %>"
                        target="_blank"
                        style="
                          display: inline-block;
                          background: #10b981;
                          color: #ffffff;
                          text-decoration: none;
                          font-size: 15px;
                          font-weight: bold;
                          padding: 14px 30px;
                          border-radius: 10px;
                        "
                      >
                        View Invitation
                      </a>
                    </td>
                  </tr>
                </table>
                <% } %>

                <p
                  style="
                    margin: 0 0 12px;
                    color: #6b7280;
                    font-size: 14px;
                    line-height: 1.7;
                  "
                >
                  If the button above doesn’t work, you can copy and paste this
                  link into your browser:
                </p>

                <% if (inviteLink) { %>
                <p
                  style="
                    margin: 0 0 24px;
                    color: #059669;
                    font-size: 14px;
                    word-break: break-all;
                    line-height: 1.7;
                  "
                >
                  <%= inviteLink %>
                </p>
                <% } %>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                style="
                  border-top: 1px solid #e5e7eb;
                  padding: 22px 30px;
                  text-align: center;
                  background: #fafafa;
                "
              >
                <p
                  style="
                    margin: 0 0 8px;
                    font-size: 13px;
                    color: #6b7280;
                    line-height: 1.6;
                  "
                >
                  This invitation was sent to
                  <strong style="color: #111827"><%= email %></strong>
                </p>

                <p
                  style="
                    margin: 0;
                    font-size: 12px;
                    color: #9ca3af;
                    line-height: 1.6;
                  "
                >
                  If you were not expecting this invitation, you can safely
                  ignore this email.
                </p>
              </td>
            </tr>
          </table>

          <!-- Bottom spacing -->
          <table width="520" cellpadding="0" cellspacing="0">
            <tr>
              <td
                align="center"
                style="padding-top: 18px; font-size: 12px; color: #9ca3af"
              >
                © <%= new Date().getFullYear() %> Eventora. All rights reserved.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>