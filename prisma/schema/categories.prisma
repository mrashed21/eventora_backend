model Categories {
  id                   String          @id @default(uuid(7))
  category_description String?
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt
  category_status      category_status @default(active)
  is_paid              Boolean         @default(false)
  category_image       String?
  category_title       String
  category_type        category_type   @default(public)
  events               Event[]

  @@index([category_title], map: "idx_categories_title")
  @@index([category_type], map: "idx_categories_type")
  @@index([category_status], map: "idx_categories_status")
  @@index([is_paid], map: "idx_categories_is_paid")
  @@map("categories")
}
