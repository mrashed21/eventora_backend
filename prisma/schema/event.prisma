model Event {
  id                String             @id @default(uuid(7))
  event_title       String
  event_image       String?
  event_date        DateTime
  event_time        String
  event_venue       String
  event_description String
  event_status      event_status       @default(active)
  is_featured       Boolean            @default(false)
  registration_fee  Float?
  organizer_id      String
  category_id       String
  userId            String?
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  invitations       Invitation[]
  reviews           Review[]
  participants      EventParticipant[]
  payments          EventPayment[]
  category          Categories         @relation(fields: [category_id], references: [id], onDelete: Cascade)
  organizer         Organizer          @relation("EventOrganizers", fields: [organizer_id], references: [id], onDelete: Cascade)
  user              User?              @relation(fields: [userId], references: [id])

  @@index([organizer_id], map: "idx_event_organizer_id")
  @@index([event_date], map: "idx_event_date")
  @@index([event_title], map: "idx_event_title")
  @@index([event_status], map: "idx_event_status")
  @@index([event_venue], map: "idx_event_venue")
  @@index([category_id], map: "idx_event_category_id")
  @@map("events")
}
